@page "/create"
@attribute [Authorize]
@inject LoanApiClient Api
@inject NavigationManager Nav

<div class="page-header">
    <h1>New Loan Application</h1>
</div>

<div class="card form-card">

    @if (_result is null)
    {
        <EditForm Model="_m" OnValidSubmit="Submit">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Applicant Name</label>
                <InputText class="form-control" @bind-Value="_m.ApplicantName" />
                <ValidationMessage For="() => _m.ApplicantName" />
            </div>

            <div class="form-group">
                <label>Loan Amount</label>
                <InputNumber class="form-control" @bind-Value="_m.LoanAmount" />
                <ValidationMessage For="() => _m.LoanAmount" />
            </div>

            <div class="form-group">
                <label>Credit Score (300–850)</label>
                <InputNumber class="form-control" @bind-Value="_m.CreditScore" />
                <ValidationMessage For="() => _m.CreditScore" />
                <small class="hint">
                    Score >= 700 + amount &lt;= 50,000 → Approved |
                    Score 650–699 + amount &lt;= 20,000 → Approved |
                    Otherwise → Rejected
                </small>
            </div>

            @if (_error is not null)
            {
                <div class="alert alert-error">@_error</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@_busy">
                    @(_busy ? "Submitting…" : "Submit Application")
                </button>
                <a class="btn" href="">Cancel</a>
            </div>
        </EditForm>
    }
    else
    {
        <!-- Show evaluation result after submit -->
        <div class="result-card">
            <div class="result-icon @(_result.Status == LoanStatus.Approved ? "approved" : "rejected")">
                @(_result.Status == LoanStatus.Approved ? "✓" : "✗")
            </div>
            <h2 class="result-title @(_result.Status == LoanStatus.Approved ? "text-approved" : "text-rejected")">
                Loan @_result.Status
            </h2>
            <p class="result-reason">@_result.Reason</p>

            <div class="result-summary">
                <div class="result-row">
                    <span>Applicant</span>
                    <strong>@_m.ApplicantName</strong>
                </div>
                <div class="result-row">
                    <span>Amount</span>
                    <strong>@_m.LoanAmount.ToString("N2")</strong>
                </div>
                <div class="result-row">
                    <span>Credit Score</span>
                    <strong>@_m.CreditScore</strong>
                </div>
                <div class="result-row">
                    <span>Decision</span>
                    <strong>
                        <span class="badge badge-@_result.Status.ToString().ToLower()">
                            @_result.Status
                        </span>
                    </strong>
                </div>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="GoToList">
                    View All Applications
                </button>
                <button class="btn" @onclick="Reset">
                    Submit Another
                </button>
            </div>
        </div>
    }

</div>

@code {
    CreateLoanDto _m = new();
    bool _busy;
    string? _error;
    LoanEvaluationResultDto? _result;

    async Task Submit()
    {
        _busy = true; _error = null;
        try
        {
            var created = await Api.CreateLoanAsync(_m);
            if (created is null)
            {
                _error = "Failed to submit application.";
                return;
            }

            _result = await Api.EvaluateAsync(created.Id);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    void GoToList() => Nav.NavigateTo("");

    void Reset()
    {
        _m = new();
        _result = null;
        _error = null;
    }
}